{
  "name": "@veltrixsecops/app-sdk",
  "version": "1.0.1",
  "description": "Official SDK for building Veltrix Security-as-Code apps — typed pipeline handler contracts, lifecycle hook types, manifest types, and React hooks.",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./pipeline": {
      "import": {
        "types": "./dist/pipeline/index.d.ts",
        "default": "./dist/pipeline/index.js"
      },
      "require": {
        "types": "./dist/pipeline/index.d.cts",
        "default": "./dist/pipeline/index.cjs"
      }
    },
    "./hooks": {
      "import": {
        "types": "./dist/hooks/index.d.ts",
        "default": "./dist/hooks/index.js"
      },
      "require": {
        "types": "./dist/hooks/index.d.cts",
        "default": "./dist/hooks/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.6.0"
  },
  "keywords": [
    "veltrix",
    "security-as-code",
    "secops",
    "app-sdk",
    "pipeline",
    "plugin"
  ],
  "license": "MIT",
  "homepage": "https://github.com/captivatortechnologies/veltrix-apps/tree/main/sdk",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/captivatortechnologies/veltrix-apps.git",
    "directory": "sdk"
  }
}
