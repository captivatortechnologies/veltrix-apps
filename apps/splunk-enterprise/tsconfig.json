{
  "compilerOptions": {
    "target": "ES2020",
    "module": "preserve",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["node", "jest"]
  },
  "include": [
    "config-types/**/*.ts",
    "lib/**/*.ts",
    "hooks/**/*.ts",
    "server/**/*.ts",
    "client/**/*.ts",
    "client/**/*.tsx"
  ],
  "exclude": ["node_modules"]
}
