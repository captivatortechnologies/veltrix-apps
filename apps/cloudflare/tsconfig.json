{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["node", "jest"]
  },
  "include": ["config-types/**/*.ts", "lib/**/*.ts", "hooks/**/*.ts", "server/**/*.ts"],
  "exclude": ["node_modules", "client"]
}
